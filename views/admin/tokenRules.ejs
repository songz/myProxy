<%- include('../layout/head.ejs') %>

<div class="container" style="margin-top:50px">
  <div class='headContainer' style="justify-content: space-between;">

    <div class="flexContainer" style="display: flex;">
      <h1>Token Rules</h1>

      <div class="navBar" style="margin-left: auto">
        <a
          class="btn-outline-dark btn"
          style="margin-right: 8px;"
          href="/admin/accessTokens"
          >
          Access Tokens
        </a>
        <a
          class="btn-outline-primary btn"
          style="margin-right: 8px;"
          href="/"
          >
          My Proxy
        </a>
        <a
          class="btn-outline-primary btn"
          style="margin-right: 8px;"
          href="/admin"
          >
          Admin
        </a>
      </div>
    </div>

    <p class="text-muted">Protect a subdomain+path by requiring an Authorization header with a valid token.</p>

    <div class="card mb-3">
      <div class="card-body">
        <div class="form-row align-items-end">
          <div class="form-group col-md-3">
            <label>Token</label>
            <select class="form-control tokenSelect"></select>
          </div>
          <div class="form-group col-md-4">
            <label>Full Domain (e.g. api.example.com)</label>
            <input class="form-control domainInput" type="text" placeholder="api.example.com">
          </div>
          <div class="form-group col-md-3">
            <label>Path (e.g. /v1, leave blank for all)</label>
            <input class="form-control pathInput" type="text" placeholder="/">
          </div>
          <div class="form-group col-md-2">
            <button class="btn btn-success createRule" style="width:100%">Add Rule</button>
          </div>
        </div>
      </div>
    </div>

    <hr />

    <div class="row">
      <div class="col-12">
        <ul class="list-group rulesList"></ul>
      </div>
    </div>

  </div>
</div>

<%- include('../layout/footer.ejs') %>
<script src="/tokenRules.js"></script>
